# Firebase project credentials (Project settings → General → Your apps → SDK setup)
# Copy this file to `.env.local` and fill in the values, then restart `npm run dev`.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Realtime Database URL — required (e.g. https://your-project-default-rtdb.firebaseio.com)
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public base URL encoded in the Live Wall QR code (the attendee-facing domain).
# Falls back to the current browser origin when unset.
VITE_PUBLIC_BASE_URL=https://your-project.web.app

# Optional client-side passcode gate for the moderation dashboard.
# Leave blank to disable the gate during local development.
VITE_ADMIN_PASSCODE=
